#!/usr/bin/env python3
import subprocess
from pathlib import Path
import sys
import pandas as pd

BASE = Path(__file__).parent
MEISAI = BASE / "meisai"

def run(cmd):
    print("\n▶", " ".join(cmd))
    r = subprocess.run(cmd)
    if r.returncode != 0:
        print("エラー:", " ".join(cmd))
        sys.exit(r.returncode)

def stop_if_need_review(path: Path):
    if not path.exists():
        print(f"\n⚠ need_review.csv が見つかりません: {path}")
        print("process_keihi.py の出力を確認してください。")
        sys.exit(2)

    df = pd.read_csv(path, encoding="utf-8-sig")
    n = len(df)

    if n > 0:
        print("\n🛑 要確認（need_review）が見つかったため停止します。")
        print(f"件数: {n}")
        print(f"確認ファイル: {path}")
        print("\n対応:")
        print("  1) need_review.csv を見てルール追加（YAML化するとここが楽）")
        print("  2) 再度 python run_pipeline.py")
        sys.exit(2)

    print("\n✅ 要確認なし（need_review=0件）。次へ進みます。")

def main():
    print("==== freee 自動会計パイプライン ====\n")

    # 1) 明細CSVマージ（combined_clean.csv）
    run(["python3", "merge_csv.py", str(MEISAI)])

    # 2) 経費分類（freee_import.csv / need_review.csv など）
    run(["python3", "process_keihi.py", "combined_clean.csv"])

    # ★ 追加：要確認があれば停止
    stop_if_need_review(BASE / "need_review.csv")

    # 3) 要確認レポート（0件でも集計は作れるが、任意）
    run(["python3", "review_queue.py"])

    # 4) freee用に分割（CSV + Excel）
    run(["python3", "split_freee_csv.py", "freee_import.csv"])

    print("\n==========================")
    print("完了 ✅")
    print("freeeにアップロードするファイル:")
    print(" freee_import_expense.xlsx")
    print(" freee_import_startup.xlsx")
    print(" freee_import_asset.xlsx")
    print("（または freee_import_split_all.xlsx）")

if __name__ == "__main__":
    main()